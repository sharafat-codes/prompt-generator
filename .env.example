# PromptPilot — copy to .env and fill in. Never commit .env.

# Postgres (Supabase → Connect → ORM → Prisma gives both of these).
# DATABASE_URL = pooled/transaction (port 6543, ?pgbouncer=true) — used by the app.
# DIRECT_URL   = session/direct (port 5432) — used by Prisma for migrations.
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="replace-me"

# OAuth sign-in (add at least one to enable login).
# GitHub: https://github.com/settings/developers → New OAuth App
#   Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
# Google: https://console.cloud.google.com/apis/credentials
#   Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Managed AI (server-only). Claude is the default provider.
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: override the model (default claude-opus-4-8). Cheaper options:
#   claude-sonnet-5 · claude-haiku-4-5
# PROMPTPILOT_MODEL="claude-sonnet-5"
